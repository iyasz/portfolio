---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="max-w-7xl w-full mx-auto">
		<div class="main w-full">
			<div class="banner">
				<div class="w-full md:h-48 h-48 bg-slate-100">
					<img src="/src/assets/img/banner.avif" alt="Banner Image" class="w-full h-full object-cover pointer-events-none grayscale-25">
				</div>
			</div>
			<div class="md:p-10 p-4 relative border-t border-slate-100">
				<div class="md:flex block items-center gap-8 md:absolute relative top-0 right-0 left-0 md:-translate-y-12 -translate-y-20 w-full">
					<div class="md:w-[20%] w-full md:block flex justify-center">
						<div class="profile_pic w-42.5 h-42.5 border-6 border-slate-300 rounded-full relative md:left-17.5 left-auto">
							<div class="status absolute md:-right-32 -right-20 -top-10">
								<div class="max-w-50 min-h-10 bg-white shadow-md rounded-full flex items-center  ">
									<p class="py-2 px-5 text-xs text-slate-400 font-medium select-none">Hey there! I am using Elaina  </p>
								</div>
								<div class="w-3 h-2 bg-white shadow-md rounded-b-full relative bottom-0 -right-5.75"></div>
								<div class="w-3 h-3 bg-white shadow-md rounded-full relative -right-2.5"></div>
							</div>

							<div class="">
								<img src="/src/assets/img/profile_decoration.gif" class="w-full h-full object-cover rounded-full absolute pointer-events-none" alt="">
								<img src="/src/assets/img/pp.avif" alt="Profile Picture" class="w-full h-full object-cover rounded-full pointer-events-none">
							</div>
							<div class="online_indicator w-7 h-7 bg-green-500 border-3 border-slate-300 rounded-full absolute bottom-2 right-2"></div>
						</div>
					</div>
					
					<div class="md:mt-12 mt-6 md:w-[80%] w-full md:flex justify-between block">
						<div class="">
							<p class="text-xs text-slate-400 md:mb-1 mb-4">@elainaenthusiast</p>
							<h1 class="text-3xl font-bold text-slate-800 flex flex-wrap leading-2.5 items-center gap-3">
								Muhammad Ilyasa 
	
								<span class="font-medium text-2xl tracking-wide">(iyasz)</span>
	
								<svg aria-label="Verified" class="x1lliihq x1n2onr6" fill="rgb(0, 149, 246)" height="18" role="img" viewBox="0 0 40 40" width="18"><title>Verified</title><path d="M19.998 3.094 14.638 0l-2.972 5.15H5.432v6.354L0 14.64 3.094 20 0 25.359l5.432 3.137v5.905h5.975L14.638 40l5.36-3.094L25.358 40l3.232-5.6h6.162v-6.01L40 25.359 36.905 20 40 14.641l-5.248-3.03v-6.46h-6.419L25.358 0l-5.36 3.094Zm7.415 11.225 2.254 2.287-11.43 11.5-6.835-6.93 2.244-2.258 4.587 4.581 9.18-9.18Z" fill-rule="evenodd"></path></svg>
							</h1>
							<h2 class="mt-2 tracking-wide text-slate-500 font-medium">Software Engineer</h2>
						</div>
						<div class="flex items-center gap-3 md:mt-0 mt-7">
							<a href="https://www.linkedin.com/in/muhammad-ilyaasa" target="_blank" class="text-sm font-medium bg-blue-500 text-white px-4 py-2 rounded-sm border-2 border-blue-500 hover:bg-blue-600 transition-colors flex items-center gap-2">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-linkedin" viewBox="0 0 16 16">
									<path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
								</svg>
								Connect 
							</a>
							<a href="" class="text-sm font-medium bg-white border-2 border-blue-500 text-blue-500 px-4 py-2 rounded-sm transition-colors">Write-Up</a>
						</div>

					</div>
				</div>
				<div class="md:mt-30 mt-0 md:gap-10 gap-0 grid grid-cols-12">
					<div class="md:col-span-8 col-span-12 md:order-0 order-1">

						<div class="md:mt-auto mt-10">
							<h2 class="text-slate-800 font-bold text-lg">About <span class="line-through">Me</span></h2>
							<div class="mt-3">
								<p class="text-slate-600">
									Hellow mellow konnichiwa.

									<br>
									Just a student trying to make sense of software development. I build stuff, break stuff, fix it, and learn something new every time.
								</p>
							</div>

						</div>

						<div class="mt-10">
							<h2 class="text-slate-800 font-bold text-lg">Tech Interests</h2>
							<div class="mt-3 flex flex-wrap gap-6">
								<img src="https://psbadge.netlify.app/b/bun.png" alt="Bun" class="w-max h-12.5 shrink-0 rounded-lg">
								<img src="https://psbadge.netlify.app/b/vue.png" alt="vue" class="w-max h-12.5 shrink-0 rounded-lg">
								<img src="https://psbadge.netlify.app/b/laravel.png" alt="laravel" class="w-max h-12.5 shrink-0 rounded-lg">
								<img src="https://psbadge.netlify.app/b/postgre.png" alt="postgre" class="w-max h-12.5 shrink-0 rounded-lg">
								<img src="https://psbadge.netlify.app/b/typescript.png" alt="typescript" class="w-max h-12.5 shrink-0 rounded-lg">
								<img src="https://psbadge.netlify.app/b/go.png" alt="Go" class="w-max h-12.5 shrink-0 rounded-lg">
								<img src="https://psbadge.netlify.app/b/redis.png" alt="redis" class="w-max h-12.5 shrink-0 rounded-lg">
							</div>

						</div>

						<div class="mt-10">
							<h2 class="text-slate-800 font-bold text-lg">Experiences</h2>
							<div class="mt-3 md:flex block gap-6">
								<div class="w-15 h-15 md:mb-auto mb-3 shrink-0 bg-slate-400 border border-slate-100">
									<img src="/src/assets/img/mss.avif" alt="Megah Sakti Singosari Logo" class="w-full h-full object-cover">
								</div>
								<div class="w-full">
									<div class="flex justify-between md:flex-row flex-col">
										<div class="md:order-0 order-1">
											<h1 class="text-slate-800 font-semibold">Fullstack Developer</h1>
											<h2 class="text-xs text-slate-600 mt-1">PT. Megah Sakti Singosari  -  Internship</h2>
										</div>
										<p class="text-xs italic font-medium text-slate-500 md:order-1 order-0">Feb 2026 - Mar 2026</p>
									</div>
									<h3 class="text-xs text-slate-600 mt-1 ms-4">
										<li>Redesigned and managed a WordPress-based online store, focusing on making the layout and features clearer and easier for customers to navigate.</li>
										<li>Built a custom online store from scratch using Nuxt.js and Supabase to replace a more expensive solution, which helped the company cut down on budget.</li>
									</h3>
								</div>
							</div>
							<div class="mt-5 md:flex block gap-6">
								<div class="w-15 h-15 md:mb-auto mb-3 shrink-0 bg-slate-400 border border-slate-100">
									<img src="/src/assets/img/sdp.avif" alt="Solusi Data Pratama Logo" class="w-full h-full object-cover">
								</div>
								<div class="w-full">
									<div class="flex justify-between md:flex-row flex-col">
										<div class="md:order-0 order-1">
											<h1 class="text-slate-800 font-semibold">Quality Assurance</h1>
											<h2 class="text-xs text-slate-600 mt-1">PT. Solusi Data Pratama  -  Internship</h2>
										</div>
										<p class="text-xs italic font-medium text-slate-500 md:order-1 order-0">Dec 2022 - Mar 2023</p>
									</div>
									<h3 class="text-xs text-slate-600 mt-1 ms-4">
										<li>Performed end-to-end testing on the application, focusing on improving error response messages to make them more understandable for users.</li>
										<li>Created detailed testing reports from an end-to-end perspective to document findings and support the development team.</li>
									</h3>
								</div>
							</div>
						</div>


					</div>
					<div class="md:col-span-4 col-span-12 md:order-1 order-0">
						<div class="w-full border-4 border-blue-300 p-3 rounded-lg md:rotate-4 rotate-0 relative">
							<div class="w-22.5 h-7.5 bg-blue-400 flex items-center justify-center absolute -top-2 -left-9 -rotate-24">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-nut-fill text-white" viewBox="0 0 16 16">
									<path d="M4.58 1a1 1 0 0 0-.868.504l-3.428 6a1 1 0 0 0 0 .992l3.428 6A1 1 0 0 0 4.58 15h6.84a1 1 0 0 0 .868-.504l3.429-6a1 1 0 0 0 0-.992l-3.429-6A1 1 0 0 0 11.42 1zm5.018 9.696a3 3 0 1 1-3-5.196 3 3 0 0 1 3 5.196"/>
								</svg>
							</div>
							<div class="md:p-5 p-3 border-3 border-slate-200 rounded-lg border-dashed">
								<div class="flex items-center gap-5 mb-6">
									<h2>
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-award-icon lucide-award text-slate-800"><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/><circle cx="12" cy="8" r="6"/></svg>
									</h2>
									<h3 class="text-slate-700 font-medium md:text-sm text-xs">Maaf masih pemula enjoyers</h3>
								</div>
								<div class="flex items-center gap-5 mb-6">
									<h2>
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin-icon lucide-map-pin text-slate-800"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
									</h2>
									<h3 class="text-slate-700 font-medium md:text-sm text-xs">Robetta, <span class="ms-1 font-semibold">West Java</span></h3>
								</div>
								<div class="flex items-start gap-5">
									<h2>
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-school-icon lucide-school text-slate-800"><path d="M14 21v-3a2 2 0 0 0-4 0v3"/><path d="M18 4.933V21"/><path d="m4 6 7.106-3.79a2 2 0 0 1 1.788 0L20 6"/><path d="m6 11-3.52 2.147a1 1 0 0 0-.48.854V19a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a1 1 0 0 0-.48-.853L18 11"/><path d="M6 4.933V21"/><circle cx="12" cy="9" r="2"/></svg>
									</h2>
									<h3 class="text-slate-700 font-medium md:text-sm text-xs">
										Bina Sarana Informatika University
										<br>
										<span class="italic text-xs text-slate-400">Informatics</span>
									</h3>
								</div>


							</div>
						</div>
					</div>
					
				</div>

			</div>

			<footer class="my-7">
				<div class="flex md:justify-between justify-center text-center md:gap-2 gap-5 md:flex-row flex-col">
					<div class="md:order-0 order-1">
						<p class="text-xs text-slate-400 tracking-widest">©2026 - Muhammad Ilyasa.</p>
					</div>
					<div class="flex gap-5 items-center justify-center md:order-1 order-0">
						<a href="https://github.com/iyasz" target="_blank" class="text-xs">
							<img src="/src/assets/icon/github.svg" alt="" class="w-5">
						</a>
						<a href="https://www.kaggle.com/muhammadilyaasa" target="_blank" class="text-xs">
							<img src="/src/assets/icon/kaggle.svg" alt="" class="w-5">
						</a>
						<a href="https://gitlab.com/iyasz" target="_blank" class="text-xs">
							<img src="/src/assets/icon/gitlab.svg" alt="" class="w-5">
						</a>
					</div>
				</div>
			</footer>


		</div>
	</div>
</Layout>
