---
interface Props {
	logo: string;
	logoAlt: string;
	role: string;
	company: string;
	type: string;
	period: string;
	descriptions: string[];
	class?: string;
}

const { logo, logoAlt, role, company, type, period, descriptions, class: className } = Astro.props;
---

<div class:list={["md:flex block gap-6", className]}>
	<div class="w-15 h-15 md:mb-auto mb-3 shrink-0 bg-slate-400 border border-slate-100">
		<img src={logo} alt={logoAlt} class="w-full h-full object-cover">
	</div>
	<div class="w-full">
		<div class="flex justify-between md:flex-row flex-col">
			<div class="md:order-0 order-1">
				<h1 class="text-slate-800 font-semibold">{role}</h1>
				<h2 class="text-xs text-slate-600 mt-1">{company}  -  {type}</h2>
			</div>
			<p class="text-xs italic font-medium text-slate-500 md:order-1 order-0">{period}</p>
		</div>
		<h3 class="text-xs text-slate-600 mt-1 ms-4">
			{descriptions.map((desc) => (
				<li>{desc}</li>
			))}
		</h3>
	</div>
</div>
